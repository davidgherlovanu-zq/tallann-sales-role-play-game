---
// Audit Log modal with filtering
---

<div class="modal-overlay dashboard-modal" id="auditLogModal">
  <div class="modal-card">
    <div class="dashboard-header">
      <div>
        <h2>Audit Log</h2>
        <p style="color:var(--text-dim); font-size:13px; margin-top:2px;">System events, errors, and session activity</p>
      </div>
      <div style="display:flex; gap:8px; align-items:center;">
        <select id="auditFilterType" onchange="loadAuditLog()" style="padding:6px 10px; border-radius:8px; border:1px solid var(--border); background:var(--card-bg); color:var(--text); font-size:13px;">
          <option value="all">All Events</option>
          <option value="error">Errors Only</option>
          <option value="warning">Warnings Only</option>
          <option value="info">Info Only</option>
        </select>
        <select id="auditFilterSource" onchange="loadAuditLog()" style="padding:6px 10px; border-radius:8px; border:1px solid var(--border); background:var(--card-bg); color:var(--text); font-size:13px;">
          <option value="all">All Sources</option>
          <option value="ElevenLabs">ElevenLabs</option>
          <option value="App">App</option>
          <option value="Scoring">Scoring</option>
          <option value="Firebase">Firebase</option>
        </select>
        <button class="btn btn-secondary" onclick="loadAuditLog()" style="font-size:13px; padding:6px 14px;">&#8635; Refresh</button>
        <a style="color:var(--text-dim); font-size:20px; cursor:pointer; padding:4px 8px;" onclick="closeAuditLog()">&times;</a>
      </div>
    </div>
    <div id="auditLogContent" style="max-height:65vh; overflow-y:auto;">
      <div class="dashboard-loading"><div class="spinner"></div><p style="color:var(--text-dim); margin-top:10px;">Loading audit log...</p></div>
    </div>
  </div>
</div>
