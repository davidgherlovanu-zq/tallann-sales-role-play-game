# Firebase Configuration
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=

# App Configuration
PUBLIC_AGENT_ID=
PUBLIC_ELEVENLABS_API_KEY=
PUBLIC_AI_PROVIDER=
PUBLIC_AI_API_KEY=

# Bubble iframe SSO
# Comma-separated exact origins allowed to send postMessage tokens into the iframe.
PUBLIC_BUBBLE_ALLOWED_ORIGINS=https://YOUR-BUBBLE.bubbleapps.io,https://YOUR-CUSTOM-DOMAIN.com
# Exact parent origin used when the iframe posts AUTH_STATUS / TOKEN_REFRESH_REQUIRED back to Bubble.
PUBLIC_BUBBLE_PARENT_ORIGIN=https://YOUR-BUBBLE.bubbleapps.io
